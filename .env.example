# Cursor Cloud Agents API key — never commit the real value.
# Create at https://cursor.com/dashboard → Integrations / API Keys
CURSOR_API_KEY=cursor_your_key_here

# Optional: require this token on /api/agent/* (browser sends Authorization: Bearer …)
# Generate a long random string; store only in .env and your browser local settings.
AGENT_PROXY_TOKEN=

# Comma-separated origins allowed for CORS (default: http://localhost:3000,http://127.0.0.1:3000)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server port when running npm run dev
PORT=3000
